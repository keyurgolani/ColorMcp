{
  "name": "mcp-color-server",
  "version": "1.0.0",
  "description": "A comprehensive Model Context Protocol server for color manipulation, palette generation, and visualization",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && npm run fix-imports",
    "fix-imports": "node scripts/fix-imports.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:check": "jest --coverage --coverageThreshold='{\"global\":{\"statements\":90,\"branches\":85,\"functions\":95,\"lines\":90}}'",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "pre-push": "npm run type-check && npm run test:coverage:check && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "color",
    "palette",
    "design",
    "accessibility",
    "visualization"
  ],
  "author": "MCP Color Server Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/mcp-color-server.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/mcp-color-server/issues"
  },
  "homepage": "https://github.com/your-org/mcp-color-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chroma-js": "^3.1.2",
    "colord": "^2.9.3",
    "handlebars": "^4.7.8",
    "joi": "^17.11.0"
  },
  "devDependencies": {
    "@types/chroma-js": "^3.1.1",
    "@types/handlebars": "^4.0.40",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.1.6",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.ts": [
      "npm run type-check"
    ]
  }
}
